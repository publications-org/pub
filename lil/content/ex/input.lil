(* LIttle Learner Interpreter, Sketch #1 *)

(require 'proofreader)
(require 'reader)
(require 'lil)

.(begin 2, 2) (* 2 readers, 2 proofreaders. *)
.(add 2, 2)
.(sub 2, 2)
.(ask "Is the sky blue?")
.(ask "Is the Littlewood-Offord problem covering the area of a circle")
.(ask "Why is the Apery's Constant proven irrational, but not yet transcendental?")
.(end 2, 1) (* 1 proofreader still listening for future sequences. *)

.(kill 0, 0) (* Kill all readers. *)
